# ============================================
# AI Overseas Daily - 环境配置模板
# 复制此文件为 .env 并填入你的配置值
# ============================================

# --- 必填：数据源 API Keys ---
# RapidAPI key（用于 Twitter、Reddit、Product Hunt 数据抓取）
# 注册 https://rapidapi.com 并订阅以下 API：
#   - twitter-api45 (雷达1+2)
#   - reddit34 (雷达4)
#   - product-hunt-scraper-api (雷达5)
RAPIDAPI_KEY=

# --- 必填：报告生成 LLM ---
# OpenAI 兼容的 LLM API 配置
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=

# --- 必填：飞书知识库分发 ---
# 在飞书开放平台创建应用，获取 App ID 和 Secret
# 并授权该应用对目标知识库的写入权限
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_WIKI_SPACE_ID=
# 可选：知识库内的父节点 token，不填则放在空间根目录
FEISHU_WIKI_PARENT_NODE_TOKEN=
# 飞书 API 域名（默认 https://open.feishu.cn，国际化版用 https://open.larksuite.com）
FEISHU_BASE_URL=https://open.feishu.cn
# 飞书知识库页面域名（如 yourorg.feishu.cn 或 yourorg.larksuite.com）
FEISHU_WIKI_DOMAIN=bytedance.feishu.cn

# --- 必填：如流群消息分发 ---
# 在如流群设置中创建 Webhook，获取 URL 和群 ID
RULIU_WEBHOOK_URL=
RULIU_GROUP_ID=

# --- 可选：博查搜索（雷达6） ---
# 不配置则跳过中文 AI 资讯检索
BOCHA_API_KEY=

# --- 可选：Twitter 精选 List ---
# 你的 X/Twitter List URL，用于雷达1
# 建议添加 AI 研究者、模型厂商、VC 分析师、数据工程账号
# 不配置或留空时，脚本会使用内置默认精选 List
X_LIST_URL=https://x.com/i/lists/2043220449883218100

# --- 可选：网络代理 ---
# 支持 PAC URL（自动解析）或直连代理地址
# 在需要翻墙访问 ArXiv/HuggingFace 的环境下配置
# http_proxy=http://pac.internal.yourcompany.com/proxy.pac
# http_proxy=http://proxy-host:port
